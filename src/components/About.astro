---
import { Image } from 'astro:assets';
import aboutPhoto from '../assets/sal/sal_1.png';

const credentials = [
  { no: '01', label: 'canfitpro Certified',        sub: 'Nationally recognized personal training certification' },
  { no: '02', label: 'Injury-First Approach',      sub: 'Every program designed around your body\'s limits and needs' },
  { no: '03', label: 'Martial Arts Instructor',    sub: 'Real fighting experience — teaches his own class locally' },
  { no: '04', label: 'Brampton Community Staple',  sub: 'Trusted across multiple gyms throughout the city' },
];
---

<section id="about" class="relative py-24 sm:py-32 bg-paper-dim border-t-2 border-ink overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">

    <!-- section header -->
    <div class="flex items-end justify-between gap-4 border-b-2 border-ink pb-5 mb-12">
      <h2 class="font-display text-6xl sm:text-7xl lg:text-8xl text-ink">About<br class="sm:hidden"/> Sal</h2>
      <span class="meta text-ink-soft pb-2 hidden sm:block">No. 02 — Profile</span>
    </div>

    <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-start">

      <!-- portrait -->
      <div class="lg:col-span-5">
        <div class="relative max-w-sm mx-auto lg:mx-0">
          <div class="duotone border-2 border-ink shadow-hard aspect-[7/9] overflow-hidden">
            <Image
              src={aboutPhoto}
              alt="Sal Modica training a client"
              widths={[320, 480, 640]}
              sizes="(max-width: 640px) 90vw, 22rem"
              class="w-full h-full object-cover object-top"
            />
          </div>
          <div class="absolute -bottom-4 -right-4 bg-blaze text-bone border-2 border-ink px-4 py-2 rotate-2">
            <span class="meta">Yrs in the trade</span>
          </div>
        </div>
      </div>

      <!-- copy + credentials -->
      <div class="lg:col-span-7">
        <p class="text-xl leading-relaxed text-ink mb-6">
          Sal Modica is a <span class="font-semibold">canfitpro certified personal trainer</span> based in
          Brampton, Ontario, with years of hands-on experience across multiple local gyms. His genuine
          investment in client outcomes has made him a <span class="font-serif italic">trusted name</span> in the
          Brampton fitness community.
        </p>
        <p class="text-lg leading-relaxed text-ink-soft mb-10">
          Beyond the weight room, Sal is a martial artist with real fighting experience who teaches his own
          class at a local gym. That same discipline and attention to form shapes every plan he builds —
          whether you're brand new or a seasoned athlete chasing the next level.
        </p>

        <!-- credential spec sheet -->
        <div class="border-2 border-ink bg-panel shadow-hard-sm divide-y-2 divide-ink/10">
          {credentials.map(({ no, label, sub }) => (
            <div class="group flex items-center gap-5 px-5 py-4 hover:bg-blaze hover:text-bone transition-colors">
              <span class="meta text-blaze group-hover:text-bone shrink-0">{no}</span>
              <div class="min-w-0">
                <p class="font-display text-xl tracking-wide leading-none">{label}</p>
                <p class="text-sm text-ink-soft group-hover:text-bone/80 mt-1">{sub}</p>
              </div>
            </div>
          ))}
        </div>

        <a href="#contact" class="group mt-8 inline-flex items-center gap-2 border-2 border-ink bg-ink text-paper meta px-7 py-4 hover:bg-blaze hover:text-bone hover:border-blaze transition-colors">
          Work With Sal
          <span class="group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>

    </div>
  </div>
</section>
