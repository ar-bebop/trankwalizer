---
import { Image } from 'astro:assets';
import heroPhoto from '../assets/sal/sal_3.png';
---

<section id="top" class="relative min-h-screen flex flex-col justify-between overflow-hidden pt-24 sm:pt-28">

  <!-- solid warm-dark zone + vivid red rule (solid red only — washes go brown) -->
  <div class="absolute top-0 right-0 h-full w-[34%] bg-panel border-l-2 border-blaze hidden lg:block pointer-events-none"></div>

  <div class="relative z-10 mx-auto max-w-7xl w-full px-4 sm:px-6 flex-1 flex items-center">
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-6 items-center w-full py-10">

      <!-- LEFT: poster type -->
      <div class="lg:col-span-7 order-2 lg:order-1">

        <div class="rise rise-1 flex flex-wrap items-center gap-x-4 gap-y-2 mb-6">
          <span class="meta border-2 border-ink px-3 py-1.5 bg-ink text-paper">No. 01 — The Trainer</span>
          <span class="meta text-ink-soft">Est. Brampton, ON</span>
        </div>

        <h1 class="select-none">
          <span class="rise rise-1 block font-display text-ink text-[24vw] sm:text-[20vw] lg:text-[12rem] xl:text-[14rem] leading-[0.8]">SAL</span>
          <span class="rise rise-2 block font-display stroke-ink text-[24vw] sm:text-[20vw] lg:text-[12rem] xl:text-[14rem] leading-[0.8] -mt-2">MODICA</span>
        </h1>

        <div class="rise rise-3 mt-7 max-w-xl border-l-2 border-blaze pl-5">
          <p class="text-lg leading-relaxed text-ink-soft">
            Health-first training built around <span class="font-serif italic text-ink">you</span>.
            Recovering from injury, managing a condition, or chasing peak performance —
            Sal builds programs that work for <span class="font-serif italic text-ink">your</span> body and your life.
          </p>
        </div>

        <div class="rise rise-4 mt-8 flex flex-col sm:flex-row gap-4">
          <a href="#contact" class="group inline-flex items-center justify-center gap-2 border-2 border-ink bg-ink text-paper meta px-7 py-4 shadow-hard-blaze hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all">
            Book A Session
            <span class="group-hover:translate-x-1 transition-transform">→</span>
          </a>
          <a href="#about" class="inline-flex items-center justify-center gap-2 border-2 border-ink bg-transparent text-ink meta px-7 py-4 hover:bg-ink hover:text-paper transition-colors">
            The Method
          </a>
        </div>
      </div>

      <!-- RIGHT: duotone portrait -->
      <div class="lg:col-span-5 order-1 lg:order-2 flex justify-center lg:justify-end">
        <div class="rise rise-2 relative w-full max-w-[20rem] sm:max-w-sm">
          <div class="duotone border-2 border-ink shadow-hard-blaze aspect-[7/10] overflow-hidden">
            <Image
              src={heroPhoto}
              alt="Sal Modica, personal trainer in Brampton, Ontario"
              widths={[320, 480, 640]}
              sizes="(max-width: 640px) 80vw, 22rem"
              loading="eager"
              fetchpriority="high"
              class="w-full h-full object-cover object-top"
            />
          </div>
          <!-- index ticket -->
          <div class="absolute -top-4 -left-4 bg-blaze text-bone border-2 border-ink px-3 py-2 -rotate-3">
            <span class="meta block leading-tight">canfitpro</span>
            <span class="meta block leading-tight text-bone/70">Certified</span>
          </div>
          <!-- location ticket -->
          <div class="absolute -bottom-4 right-6 bg-ink text-paper border-2 border-ink px-3 py-2 rotate-2 shadow-hard-sm">
            <span class="meta">◎ Brampton, ON</span>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- marquee floor -->
  <div class="relative z-10 border-y-2 border-ink bg-ink text-paper overflow-hidden">
    <div class="marquee py-3">
      {Array.from({ length: 2 }).map((_, half) => (
        <div class="flex items-center shrink-0" aria-hidden={half === 1 ? 'true' : undefined}>
          {Array.from({ length: 3 }).flatMap(() =>
            ['Strength', 'Injury Recovery', 'Martial Arts', 'Conditioning', 'Wellness Coaching', 'Discipline']
          ).map((w) => (
            <span class="flex items-center">
              <span class="font-display text-2xl tracking-wide px-6">{w}</span>
              <span class="text-blaze text-xl">✶</span>
            </span>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>
