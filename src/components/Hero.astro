---
---

<section class="relative min-h-screen flex items-center bg-dark overflow-hidden">
  <!-- Ambient glow accents -->
  <div class="absolute top-0 right-0 w-[36rem] h-[36rem] bg-brand/10 rounded-full blur-3xl -translate-y-1/3 translate-x-1/3 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-brand/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/4 pointer-events-none"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 pt-24 pb-20 w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Text -->
      <div class="order-2 lg:order-1">
        <div class="inline-flex items-center gap-2 bg-brand/10 border border-brand/30 text-brand text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded-full mb-8">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          canfitpro Certified
        </div>

        <h1 class="text-7xl md:text-8xl lg:text-9xl font-bold text-white leading-none mb-5">
          SAL<br/><span class="text-brand">MODICA</span>
        </h1>

        <p class="text-white/50 text-sm font-medium tracking-widest uppercase mb-6">
          Personal Trainer &bull; Brampton, Ontario
        </p>

        <p class="text-white/60 text-lg leading-relaxed mb-10 max-w-lg">
          Health-first training built around <em>you</em>. Whether you're recovering from an injury,
          managing a chronic condition, or chasing peak performance — Sal builds programs
          that actually work for your body and your life.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#contact" class="bg-brand hover:bg-brand-dark text-white font-semibold px-8 py-4 text-sm tracking-widest uppercase transition-colors text-center">
            Book a Session
          </a>
          <a href="#about" class="border border-white/30 hover:border-white/60 text-white/80 hover:text-white font-semibold px-8 py-4 text-sm tracking-widest uppercase transition-colors text-center">
            Learn More
          </a>
        </div>
      </div>

      <!-- Photo placeholder -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
        <div class="relative w-full max-w-xs sm:max-w-sm">
          <!-- PLACEHOLDER: swap this div for an <Image> component with Sal's photo -->
          <div class="aspect-[3/4] bg-dark-alt border border-white/10 rounded-2xl flex flex-col items-center justify-center gap-3">
            <svg class="w-20 h-20 text-white/10" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
            </svg>
            <span class="text-white/20 text-xs tracking-widest uppercase">Trainer photo</span>
          </div>
          <div class="absolute -bottom-4 -left-4 w-24 h-24 bg-brand/15 rounded-xl -z-10"></div>
          <div class="absolute -top-4 -right-4 w-14 h-14 bg-brand/10 rounded-xl -z-10"></div>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll cue -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 text-white/25 text-xs tracking-widest uppercase animate-bounce">
    <span>Scroll</span>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
