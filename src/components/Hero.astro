---
import { Image } from 'astro:assets';
import heroPhoto from '../assets/sal/sal_3.png';
---

<section class="relative min-h-screen flex items-center bg-dark overflow-hidden">
  <!-- Ambient glow accents -->
  <div class="absolute top-0 right-0 w-[36rem] h-[36rem] bg-brand/10 rounded-full blur-3xl -translate-y-1/3 translate-x-1/3 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-brand/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/4 pointer-events-none"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 pt-24 pb-20 w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Text -->
      <div class="order-2 lg:order-1">
        <div class="inline-flex items-center gap-2 bg-brand/10 border border-brand/30 text-brand text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded-full mb-8">
          <svg class="w-4 h-4" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          canfitpro Certified
        </div>

        <h1 class="text-7xl md:text-8xl lg:text-9xl font-bold text-white leading-none mb-5">
          SAL<br/><span class="text-brand">MODICA</span>
        </h1>

        <p class="text-white/50 text-sm font-medium tracking-widest uppercase mb-6">
          Personal Trainer &bull; Brampton, Ontario
        </p>

        <p class="text-white/60 text-lg leading-relaxed mb-10 max-w-lg">
          Health-first training built around <em>you</em>. Whether you're recovering from an injury,
          managing a chronic condition, or chasing peak performance — Sal builds programs
          that actually work for your body and your life.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#contact" class="bg-brand hover:bg-brand-dark text-white font-semibold px-8 py-4 text-sm tracking-widest uppercase transition-colors text-center">
            Book a Session
          </a>
          <a href="#about" class="border border-white/30 hover:border-white/60 text-white/80 hover:text-white font-semibold px-8 py-4 text-sm tracking-widest uppercase transition-colors text-center">
            Learn More
          </a>
        </div>
      </div>

      <!-- Photo -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
        <div class="relative w-full max-w-xs sm:max-w-sm">
          <div class="relative aspect-[7/12] rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-black/60">
            <Image
              src={heroPhoto}
              alt="Sal Modica, personal trainer in Brampton, Ontario"
              widths={[320, 480, 640]}
              sizes="(max-width: 640px) 80vw, 24rem"
              class="w-full h-full object-cover object-center"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-dark/80 via-dark/10 to-transparent pointer-events-none"></div>
          </div>
          <!-- Location badge -->
          <div class="absolute -bottom-5 -left-5 flex items-center gap-2.5 bg-dark-alt/90 backdrop-blur border border-brand/30 rounded-xl px-4 py-3 shadow-xl">
            <svg class="w-4 h-4 text-brand flex-shrink-0" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-white/80 text-xs font-semibold tracking-widest uppercase">Brampton, ON</span>
          </div>
          <div class="absolute -top-4 -right-4 w-14 h-14 bg-brand/10 rounded-xl -z-10"></div>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll cue -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 text-white/25 text-xs tracking-widest uppercase animate-bounce" aria-hidden="true">
    <span>Scroll</span>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
