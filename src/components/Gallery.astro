---
import { Image } from 'astro:assets';
import sal1 from '../assets/sal/sal_1.png';
import sal2 from '../assets/sal/sal_2.png';
import sal3 from '../assets/sal/sal_3.png';
import sal4 from '../assets/sal/sal_4.png';

const shots = [
  { img: sal1, label: 'Strength',     no: '01' },
  { img: sal2, label: 'Technique',    no: '02' },
  { img: sal3, label: 'Discipline',   no: '03' },
  { img: sal4, label: 'Conditioning', no: '04' },
];
---

<section id="gallery" class="relative py-24 sm:py-32 bg-paper-dim border-t-2 border-ink">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">

    <div class="flex items-end justify-between gap-4 border-b-2 border-ink pb-5 mb-12">
      <div>
        <span class="meta text-blaze block mb-3">No. 04 — In The Gym</span>
        <h2 class="font-display text-6xl sm:text-7xl lg:text-8xl text-ink">Training<br class="sm:hidden"/> In Action</h2>
      </div>
      <p class="meta text-ink-soft pb-2 hidden md:block max-w-[15rem] text-right normal-case tracking-normal" style="font-size:0.8rem">
        No posing, no filters. Real work — hover to see it in colour.
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5">
      {shots.map(({ img, label, no }, i) => (
        <figure class={`group relative ${i % 2 === 1 ? 'lg:translate-y-8' : ''}`}>
          <div class="duotone border-2 border-ink shadow-hard-sm aspect-[7/10] overflow-hidden">
            <Image
              src={img}
              alt={`Sal Modica training — ${label.toLowerCase()}`}
              widths={[300, 450, 600]}
              sizes="(max-width: 1024px) 45vw, 18rem"
              class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
            />
          </div>
          <figcaption class="absolute bottom-0 left-0 right-0 z-[3] flex items-center justify-between px-3 py-2.5 bg-ink text-paper border-2 border-ink -mb-px">
            <span class="font-display text-lg tracking-wide">{label}</span>
            <span class="meta text-blaze">{no}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
