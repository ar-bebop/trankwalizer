---
import { Image } from 'astro:assets';
import sal1 from '../assets/sal/sal_1.png';
import sal2 from '../assets/sal/sal_2.png';
import sal3 from '../assets/sal/sal_3.png';
import sal4 from '../assets/sal/sal_4.png';

const shots = [
  { img: sal1, label: 'Strength' },
  { img: sal2, label: 'Technique' },
  { img: sal3, label: 'Discipline' },
  { img: sal4, label: 'Conditioning' },
];
---

<section id="gallery" class="relative py-24 bg-dark overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[40rem] h-[40rem] bg-brand/8 rounded-full blur-3xl -translate-y-1/2 pointer-events-none"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-brand text-xs font-semibold tracking-widest uppercase mb-3">In the Gym</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white">Training in Action</h2>
      <p class="text-white/50 text-lg max-w-2xl mx-auto mt-5">
        No posing, no filters — just real work. Here's what training with Sal actually looks like.
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 lg:pb-8">
      {shots.map(({ img, label }, i) => (
        <div class={`group relative aspect-[7/12] rounded-2xl overflow-hidden border border-white/10 transition-transform duration-300 ${i % 2 === 1 ? 'lg:translate-y-8' : ''}`}>
          <Image
            src={img}
            alt={`Sal Modica training — ${label.toLowerCase()}`}
            widths={[300, 450, 600]}
            sizes="(max-width: 1024px) 45vw, 18rem"
            class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
          />
          <!-- Bottom fade -->
          <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/15 to-transparent opacity-70 group-hover:opacity-90 transition-opacity duration-300"></div>
          <!-- Teal ring on hover -->
          <div class="absolute inset-0 rounded-2xl ring-2 ring-transparent group-hover:ring-brand/60 transition-all duration-300"></div>
          <!-- Label -->
          <span class="absolute bottom-4 left-4 text-white font-bold tracking-widest uppercase text-sm translate-y-3 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
            {label}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
