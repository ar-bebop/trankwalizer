---
const services = [
  {
    no: '01',
    title: 'Personal Training',
    description:
      'One-on-one programming built around your goals, fitness level, and schedule. Every session is intentional — no filler, no guesswork.',
  },
  {
    no: '02',
    title: 'Injury Recovery & Prevention',
    description:
      'Programs that work around existing injuries while actively rebuilding strength and cutting the risk of future ones. Your safety comes first.',
  },
  {
    no: '03',
    title: 'Martial Arts Training',
    description:
      'Learn from a practitioner with real experience. Fitness, self-defence, or discipline — Sal breaks down fundamentals in a safe, structured space.',
  },
  {
    no: '04',
    title: 'Health & Wellness Coaching',
    description:
      'A holistic view of your wellbeing — lifestyle guidance, exercise planning, and nutrition awareness to build sustainable, healthy habits.',
  },
];

const formats = [
  {
    no: '01',
    label: 'Routine Writing',
    sub: 'A custom program built for you — train on your own schedule, no sessions required.',
  },
  {
    no: '02',
    label: 'In-Person Sessions',
    sub: 'Hands-on coaching at the location you choose: your gym, your home, wherever you train.',
  },
  {
    no: '03',
    label: 'Remote Sessions',
    sub: 'Live virtual coaching — same attention, wherever you are.',
  },
  {
    no: '04',
    label: 'Consultations',
    sub: 'A one-off assessment, form check, or programming advice when that\'s all you need.',
  },
  {
    no: '05',
    label: 'App Programming',
    sub: 'Routines delivered through a coaching app — primarily Everfit, other platforms on request.',
  },
];
---

<section id="services" class="relative py-24 sm:py-32 bg-paper border-t-2 border-ink">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">

    <!-- header -->
    <div class="flex items-end justify-between gap-4 border-b-2 border-ink pb-5 mb-12">
      <div>
        <span class="meta text-blaze block mb-3">No. 03 — What Sal Offers</span>
        <h2 class="font-display text-6xl sm:text-7xl lg:text-8xl text-ink">The Services</h2>
      </div>
      <p class="meta text-ink-soft pb-2 hidden md:block max-w-[14rem] text-right normal-case tracking-normal" style="font-size:0.8rem">
        No cookie-cutter plans. Built around the person in front of him.
      </p>
    </div>

    <!-- grid with shared brutalist borders -->
    <div class="grid sm:grid-cols-2 border-2 border-ink shadow-hard bg-panel">
      {services.map(({ no, title, description }, i) => (
        <div class={`group relative p-8 sm:p-10 transition-colors hover:bg-blaze hover:text-bone
          border-ink/15
          ${i % 2 === 0 ? 'sm:border-r-2' : ''}
          ${i < 2 ? 'border-b-2' : ''}`}>
          <span class="font-display text-7xl text-paper-deep group-hover:text-bone/30 leading-none transition-colors">{no}</span>
          <h3 class="font-display text-3xl tracking-wide text-ink group-hover:text-bone mt-3 mb-3 transition-colors">{title}</h3>
          <p class="text-ink-soft group-hover:text-bone/85 leading-relaxed transition-colors">{description}</p>
          <span class="meta absolute top-8 right-8 text-ink/0 group-hover:text-bone transition-colors">→</span>
        </div>
      ))}
    </div>

    <!-- ways to train -->
    <div class="mt-16 grid lg:grid-cols-12 gap-8 lg:gap-12 items-start">
      <div class="lg:col-span-4">
        <span class="meta text-blaze block mb-3">Ways To Train</span>
        <h3 class="font-display text-4xl sm:text-5xl text-ink mb-4">Train Your<br/>Way</h3>
        <p class="text-ink-soft leading-relaxed max-w-sm">
          Pick one or combine several — most clients mix a few.
          Every format is shaped around <span class="font-serif italic text-ink">your</span> goals, body, and life.
        </p>
      </div>

      <!-- format spec sheet -->
      <div class="lg:col-span-8 border-2 border-ink bg-panel shadow-hard-sm divide-y-2 divide-ink/10">
        {formats.map(({ no, label, sub }) => (
          <div class="group flex items-center gap-5 px-5 py-5 hover:bg-blaze hover:text-bone transition-colors">
            <span class="meta text-blaze group-hover:text-bone shrink-0">{no}</span>
            <div class="min-w-0">
              <p class="font-display text-xl tracking-wide leading-none">{label}</p>
              <p class="text-sm text-ink-soft group-hover:text-bone/80 mt-1.5">{sub}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- pricing callout -->
    <div class="mt-10 border-2 border-ink bg-panel text-ink shadow-hard-blaze p-8 sm:p-12">
      <div class="grid lg:grid-cols-12 gap-6 items-center">
        <div class="lg:col-span-8">
          <span class="meta text-blaze block mb-3">Pricing</span>
          <p class="font-display text-3xl sm:text-4xl leading-tight tracking-wide">
            Flexible rates — set by location, gym,<br class="hidden sm:block"/>
            frequency &amp; <span class="font-serif italic lowercase tracking-normal">your</span> goals.
          </p>
        </div>
        <div class="lg:col-span-4 lg:text-right">
          <a href="#contact" class="group inline-flex items-center gap-2 border-2 border-ink bg-blaze text-bone meta px-7 py-4 hover:bg-ink hover:text-paper hover:border-ink transition-colors">
            Get A Quote
            <span class="group-hover:translate-x-1 transition-transform">→</span>
          </a>
        </div>
      </div>
    </div>

  </div>
</section>
