---
const testimonials = [
  {
    name: 'Alexandre R.',
    context: 'Managing Type 1 Diabetes',
    quote:
      "Sal built a routine around my health condition that I never thought was possible. He helped me regain weight I had lost and gave me a structured approach to exercise and diet that's made managing my diabetes genuinely easier. He took the time to actually understand what I was dealing with.",
    initials: 'AR',
    color: 'bg-teal-700',
    hasPhoto: false,
  },
  {
    name: 'Gabriel R.',
    context: 'Varsity Football Athlete',
    quote:
      "I played football at the varsity level, so my standards are high. Sal identified gaps in my strength and movement that I hadn't even noticed, and built a program targeting exactly those weaknesses. The improvements in my performance were real and measurable.",
    initials: 'GR',
    color: 'bg-blue-700',
    hasPhoto: false,
  },
  {
    name: 'Shaylah D.',
    context: 'New to the Gym',
    quote:
      "I was completely new to the gym and honestly intimidated by everything. Sal was patient and took me through the fundamentals at my own pace. By the time we were done I had the knowledge and the confidence to show up on my own and actually know what I was doing.",
    initials: 'SD',
    color: 'bg-violet-700',
    hasPhoto: false,
  },
  {
    name: 'Mary B.',
    context: 'Injury Recovery & Weight Loss',
    quote:
      "I had tried other trainers before and always ended up with pain or setbacks. Sal was the first one who really listened. He structured everything around my injuries and my age, and somehow made the whole process feel safe. I lost the weight I wanted and I feel better than I have in years.",
    initials: 'MB',
    color: 'bg-rose-700',
    hasPhoto: false,
  },
];
---

<section id="testimonials" class="py-24 bg-dark-alt">
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-16">
      <p class="text-brand text-xs font-semibold tracking-widest uppercase mb-3">From Clients</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-5">Results Speak</h2>
      <p class="text-white/50 text-lg max-w-xl mx-auto">
        Real people, real outcomes. Here's what some of Sal's clients have to say.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {testimonials.map(({ name, context, quote, initials, color, hasPhoto }) => (
        <div class="bg-dark border border-white/8 rounded-2xl p-8 flex flex-col gap-6">

          <!-- Stars -->
          <div class="flex gap-1" aria-label="5 stars">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-4 h-4 text-brand" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <blockquote class="text-white/65 leading-relaxed flex-1">
            &ldquo;{quote}&rdquo;
          </blockquote>

          <div class="flex items-center gap-4 pt-2 border-t border-white/8">
            {hasPhoto ? (
              /* PLACEHOLDER: replace with <Image> for clients who provide a photo */
              <div class={`w-11 h-11 rounded-full ${color} flex items-center justify-center flex-shrink-0`}>
                <span class="text-white text-sm font-bold">{initials}</span>
              </div>
            ) : (
              <div class={`w-11 h-11 rounded-full ${color} flex items-center justify-center flex-shrink-0`}>
                <span class="text-white text-sm font-bold">{initials}</span>
              </div>
            )}
            <div>
              <p class="text-white font-semibold text-sm">{name}</p>
              <p class="text-white/40 text-xs mt-0.5">{context}</p>
            </div>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
