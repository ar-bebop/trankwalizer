---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import gabrielPhoto  from '../assets/testimonials/gabriel_r.jpeg';
import shaylahPhoto  from '../assets/testimonials/shaylah_d.jpg';
import alexandrePhoto from '../assets/testimonials/alexandre_r.jpg';
import maryPhoto      from '../assets/testimonials/mary_b.jpg';

const linkedinIcon = `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`;
const instagramIcon = `<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>`;

const testimonials: {
  name: string;
  context: string;
  quote: string;
  photo?: ImageMetadata;
  social?: { label: string; href: string; icon: string };
}[] = [
  {
    name: 'Alexandre R.',
    context: 'Managing Type 1 Diabetes',
    quote:
      "Sal built a routine around my health condition that I never thought was possible. He helped me regain weight I had lost and gave me a structured approach to exercise and diet that's made managing my diabetes genuinely easier. He took the time to actually understand what I was dealing with.",
    photo: alexandrePhoto,
    social: { label: 'LinkedIn', href: 'https://www.linkedin.com/in/ar-a19g/', icon: linkedinIcon },
  },
  {
    name: 'Gabriel R.',
    context: 'Varsity Football Athlete',
    quote:
      "I played football at the varsity level, so my standards are high. Sal identified gaps in my strength and movement that I hadn't even noticed, and built a program targeting exactly those weaknesses. The improvements in my performance were real and measurable.",
    photo: gabrielPhoto,
    social: { label: 'LinkedIn', href: 'https://www.linkedin.com/in/gabrieldribeiro/', icon: linkedinIcon },
  },
  {
    name: 'Shaylah D.',
    context: 'New to the Gym',
    quote:
      "I was completely new to the gym and honestly intimidated by everything. Sal was patient and took me through the fundamentals at my own pace. By the time we were done I had the knowledge and the confidence to show up on my own and actually know what I was doing.",
    photo: shaylahPhoto,
    social: { label: 'Instagram', href: 'https://www.instagram.com/_shxylxh_', icon: instagramIcon },
  },
  {
    name: 'Mary B.',
    context: 'Injury Recovery & Weight Loss',
    quote:
      "I had tried other trainers before and always ended up with pain or setbacks. Sal was the first one who really listened. He structured everything around my injuries and my age, and somehow made the whole process feel safe. I lost the weight I wanted and I feel better than I have in years.",
    photo: maryPhoto,
    social: { label: 'Instagram', href: 'https://www.instagram.com/mmod1970', icon: instagramIcon },
  },
];
---

<section id="testimonials" class="relative py-24 sm:py-32 bg-paper border-t-2 border-ink">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">

    <div class="flex items-end justify-between gap-4 border-b-2 border-ink pb-5 mb-12">
      <div>
        <span class="meta text-blaze block mb-3">No. 05 — From Clients</span>
        <h2 class="font-display text-6xl sm:text-7xl lg:text-8xl text-ink">The Proof</h2>
      </div>
      <p class="meta text-ink-soft pb-2 hidden md:block">Real people · Real outcomes</p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {testimonials.map(({ name, context, quote, photo, social }, i) => (
        <figure class="group relative flex flex-col border-2 border-ink bg-panel shadow-hard-sm hover:shadow-hard transition-shadow p-7 sm:p-8">

          <div class="flex items-center justify-between mb-5">
            <div class="flex gap-1" aria-label="5 out of 5 stars" role="img">
              {Array.from({ length: 5 }).map(() => (
                <svg class="w-4 h-4 text-blaze" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <span class="meta text-paper-deep">0{i + 1}</span>
          </div>

          <blockquote class="font-serif text-lg leading-relaxed text-ink flex-1">
            &ldquo;{quote}&rdquo;
          </blockquote>

          <figcaption class="flex items-center gap-4 mt-6 pt-5 border-t-2 border-ink/10">
            {photo && (
              <Image
                src={photo}
                alt={name}
                width={48}
                height={48}
                class="w-12 h-12 border-2 border-ink object-cover shrink-0"
              />
            )}
            <div class="flex-1 min-w-0">
              <p class="font-display text-lg tracking-wide leading-none">{name}</p>
              <p class="meta text-ink-soft mt-1.5" style="font-size:0.65rem">{context}</p>
            </div>
            {social && (
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${name} on ${social.label}`}
                class="w-9 h-9 border-2 border-ink flex items-center justify-center text-ink hover:bg-blaze hover:text-bone hover:border-blaze transition-colors shrink-0"
              >
                <svg class="w-4 h-4" aria-hidden="true" fill="currentColor" viewBox="0 0 24 24" set:html={social.icon}/>
              </a>
            )}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
